---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  // Sort projects by order to determine the sequence for "Next Project"
  const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
  
  return sortedProjects.map((project, index) => {
    // Loop back to the first project if we're on the last one
    const nextProject = index === sortedProjects.length - 1 
      ? sortedProjects[0] 
      : sortedProjects[index + 1];

    return {
      params: { slug: project.slug },
      props: { project, nextProject },
    };
  });
}

const { project, nextProject } = Astro.props;

// Helper to convert plain text with double newlines into array of paragraphs
const renderText = (text?: string) => {
  if (!text) return [];
  return text.split('\n\n').filter(Boolean);
};

const images = project.data.images || [];
---

<BaseLayout 
  title={`${project.data.title} — Omar Zaghloul`} 
  description={project.data.heroTagline || project.data.subtitle}
  ogImage={project.data.thumbnail}
>
  <main class="w-full bg-bg">
    
    <!-- Reading Progress Bar -->
    <div class="fixed top-0 left-0 z-50 h-[2px] w-full bg-border/10">
      <div id="slug-progress-bar" class="h-full w-0 bg-accent shadow-[0_0_15px_-2px_rgba(0,229,255,0.7)]"></div>
    </div>
    <!-- 1. HERO SECTION -->
    <section class="relative h-[80dvh] w-full overflow-hidden bg-surface">
      <!-- Parallax Hero Image -->
      <Image
        id="project-hero-img" 
        src={project.data.thumbnail} 
        alt={project.data.title} 
        format="webp"
        quality={85}
        class="absolute inset-0 h-[120%] w-full object-cover"
        transition:name={project.slug}
      />
      <!-- Bottom Dark Gradient Overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/40 to-transparent"></div>
      
      <!-- Title Overlay -->
      <div class="absolute bottom-0 left-0 w-full px-6 pb-12 lg:px-16">
        <div class="mx-auto w-full max-w-7xl">
          <h1 class="font-display text-[clamp(2.5rem,10vw,7rem)] font-bold leading-none tracking-tight text-text">
            {project.data.title}
          </h1>
          <p class="mt-4 font-display text-xl text-text/80 md:text-2xl max-w-3xl">
            {project.data.heroTagline || project.data.subtitle}
          </p>
        </div>
      </div>
    </section>

    <!-- Metadata Row -->
    <section class="border-b border-border/50 px-6 py-8 lg:px-16">
      <div class="mx-auto flex w-full max-w-7xl flex-wrap gap-8 md:gap-16">
        <div class="flex flex-col">
          <span class="mb-1 text-xs font-semibold uppercase tracking-wider text-text-muted">Year</span>
          <span class="font-body text-base text-text">{project.data.year}</span>
        </div>
        <div class="flex flex-col">
          <span class="mb-1 text-xs font-semibold uppercase tracking-wider text-text-muted">Role</span>
          <span class="font-body text-base text-text">{project.data.role}</span>
        </div>
        <div class="flex flex-col">
          <span class="mb-1 text-xs font-semibold uppercase tracking-wider text-text-muted">Category</span>
          <span class="font-body text-base text-text">{project.data.category}</span>
        </div>
        <div class="flex flex-col lg:ml-auto">
          <span class="mb-2 text-xs font-semibold uppercase tracking-wider text-text-muted">Tech Stack</span>
          <div class="flex flex-wrap gap-2">
            {project.data.tech.map((techItem, index) => (
              <span class={`rounded-full px-3 py-1 text-xs font-medium ${index === 0 ? 'bg-accent/10 text-accent border border-accent/20' : 'bg-surface text-text-muted border border-border/50'}`}>
                {techItem}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 2. CONTENT BODY -->
    <section class="px-6 py-24 lg:px-16">
      <div class="mx-auto w-full max-w-[720px]">
        
        <!-- The Problem -->
        <div class="content-section fade-up-section mb-16">
          <h2 class="mb-6 font-display text-3xl font-bold text-text">The Problem</h2>
          <div class="font-body text-lg leading-[1.75] text-text/80 space-y-6">
            {renderText(project.data.problem).map(p => <p>{p}</p>)}
          </div>
        </div>

        <!-- Optional Screenshot 1 -->
        {images[0] && (
          <div class="fade-up-section my-20 w-full">
            <div class="overflow-hidden rounded-xl bg-surface border border-border/50 p-2 shadow-2xl">
              <Image src={images[0].src} alt={images[0].alt} format="webp" loading="lazy" decoding="async" class="w-full rounded-lg object-contain bg-bg aspect-video md:aspect-auto" />
            </div>
            {images[0].caption && <p class="mt-4 text-center text-sm text-text-muted">{images[0].caption}</p>}
          </div>
        )}

        <!-- The Solution -->
        <div class="content-section fade-up-section mb-16">
          <h2 class="mb-6 font-display text-3xl font-bold text-text">The Solution</h2>
          <div class="font-body text-lg leading-[1.75] text-text/80 space-y-6">
            {renderText(project.data.solution).map(p => <p>{p}</p>)}
          </div>
        </div>

        <!-- Optional Screenshot 2 -->
        {images[1] && (
          <div class="fade-up-section my-20 w-full">
            <div class="overflow-hidden rounded-xl bg-surface border border-border/50 p-2 shadow-2xl">
              <Image src={images[1].src} alt={images[1].alt} format="webp" loading="lazy" decoding="async" class="w-full rounded-lg object-contain bg-bg aspect-video md:aspect-auto" />
            </div>
            {images[1].caption && <p class="mt-4 text-center text-sm text-text-muted">{images[1].caption}</p>}
          </div>
        )}

        <!-- Technical Decisions -->
        <div class="content-section fade-up-section mb-16">
          <h2 class="mb-6 font-display text-3xl font-bold text-text">Technical Decisions</h2>
          <div class="font-body text-lg leading-[1.75] text-text/80 space-y-6">
            {renderText(project.data.technicalDecisions).map(p => <p>{p}</p>)}
          </div>
        </div>

        <!-- Optional Screenshot 3 -->
        {images[2] && (
          <div class="fade-up-section my-20 w-full">
            <div class="overflow-hidden rounded-xl bg-surface border border-border/50 p-2 shadow-2xl">
              <Image src={images[2].src} alt={images[2].alt} format="webp" loading="lazy" decoding="async" class="w-full rounded-lg object-contain bg-bg aspect-video md:aspect-auto" />
            </div>
            {images[2].caption && <p class="mt-4 text-center text-sm text-text-muted">{images[2].caption}</p>}
          </div>
        )}

        <!-- Current Status -->
        <div class="content-section fade-up-section mb-8">
          <h2 class="mb-6 font-display text-3xl font-bold text-text">Where it Stands</h2>
          <div class="font-body text-lg leading-[1.75] text-text/80 space-y-6">
            {renderText(project.data.whereItStands).map(p => <p>{p}</p>)}
          </div>
        </div>
        
        <!-- Any remaining screenshots -->
        {images.slice(3).map(img => (
          <div class="fade-up-section my-20 w-full">
            <div class="overflow-hidden rounded-xl bg-surface border border-border/50 p-2 shadow-2xl">
              <Image src={img.src} alt={img.alt} format="webp" loading="lazy" decoding="async" class="w-full rounded-lg object-contain bg-bg aspect-video md:aspect-auto" />
            </div>
            {img.caption && <p class="mt-4 text-center text-sm text-text-muted">{img.caption}</p>}
          </div>
        ))}
      </div>
    </section>

    <!-- 3. NEXT PROJECT -->
    {nextProject && (
      <a href={`/projects/${nextProject.slug}`} class="block group w-full border-t border-border/50 bg-surface/30 transition-colors hover:bg-surface/80">
        <div class="mx-auto flex w-full max-w-7xl flex-col items-center justify-center px-6 py-32 text-center lg:px-16">
          <span class="mb-6 text-sm font-semibold uppercase tracking-widest text-text-muted">Next Project</span>
          <h2 class="mb-12 font-display text-4xl font-bold text-text transition-colors group-hover:text-accent md:text-5xl lg:text-7xl">
            {nextProject.data.title}
          </h2>
          <div class="relative aspect-[16/9] md:aspect-[21/9] w-full max-w-4xl overflow-hidden rounded-2xl border border-border/50">
            <Image 
              src={nextProject.data.thumbnail} 
              alt={nextProject.data.title} 
              format="webp"
              loading="lazy" 
              decoding="async"
              class="h-full w-full object-cover opacity-70 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105 group-hover:opacity-100"
              transition:name={nextProject.slug}
            />
            <!-- Subtle dark overlay on default state -->
            <div class="absolute inset-0 bg-bg/20 transition-opacity duration-700 group-hover:opacity-0"></div>
          </div>
        </div>
      </a>
    )}

    <!-- 4. FOOTER -->
    <Footer />
  </main>

  <script>
    import { gsap } from "gsap";
    import ScrollTrigger from "gsap/ScrollTrigger";

    // Register ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    const initProjectAnimations = () => {
      // Accessibility Check for Reduced Motion
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        gsap.set("#project-hero-img, .fade-up-section, #slug-progress-bar", { opacity: 1, y: 0 });
        return;
      }

      // Ensure GSAP kills old tweens if navigation event fires multiple times
      gsap.killTweensOf("#project-hero-img, .fade-up-section, #slug-progress-bar");
      
      // Top Reading Progress Bar Mapping
      gsap.fromTo(
        "#slug-progress-bar",
        { width: "0%" },
        {
          width: "100%",
          ease: "none",
          scrollTrigger: {
            trigger: "body",
            start: "top top",
            end: "bottom bottom",
            scrub: true,
          }
        }
      );
      
      // Hero Parallax Effect (creates 0.5x scroll speed visually)
      gsap.fromTo(
        "#project-hero-img",
        { y: 0 },
        {
          y: "20%",
          ease: "none",
          scrollTrigger: {
            trigger: "body",
            start: "top top",
            end: "bottom top",
            scrub: true,
          }
        }
      );

      // Section Fade Ups
      const fadeSections = gsap.utils.toArray(".fade-up-section");
      fadeSections.forEach((section: any) => {
        gsap.fromTo(
          section,
          { y: 40, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: section,
              start: "top 85%",
            }
          }
        );
      });
    };

    // Astro view transitions event
    document.addEventListener("astro:page-load", initProjectAnimations);
  </script>
</BaseLayout>
