---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Omar Zaghloul — Product & Project Manager, Software Developer, AI & Automation expert & RuneX Founder"
  description="Project manager and product builder specializing in technical solutions, and AI tools."
  ogImage="/avatar/hero-avatar.png"
>
  <section class="relative flex min-h-[100dvh] w-full items-center justify-center overflow-hidden bg-bg px-6 lg:px-16 border-b border-border/50">
    <!-- Noise Overlay -->
    <div class="pointer-events-none absolute inset-0 z-0 h-full w-full opacity-[0.03]">
      <svg class="h-full w-full">
        <filter id="noise">
          <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#noise)" />
      </svg>
    </div>

    <!-- Main Hero Container -->
    <div class="relative z-10 flex w-full max-w-7xl flex-col-reverse items-center justify-between pt-24 pb-12 lg:flex-row lg:py-0">
      
      <!-- Text Content (Left) -->
      <div class="relative z-20 mt-12 flex flex-col items-center text-center lg:mt-0 lg:w-1/2 lg:items-start lg:text-left">
        <h1 id="hero-name" class="font-display text-[clamp(2.5rem,10vw,6rem)] font-bold leading-none tracking-tight text-text opacity-0">
          Omar <span class="relative inline-block whitespace-nowrap">Zaghloul<span class="absolute bottom-2 left-0 -z-10 h-[0.14em] w-full bg-accent/80"></span></span>
        </h1>
        <h2 id="hero-position" class="mt-4 font-display text-2xl font-light tracking-wide text-text/90 opacity-0 md:text-3xl">
          Product Engineer & AI Automation Specialist
        </h2>
        <p id="hero-desc" class="mt-6 max-w-md font-body text-lg text-text-muted opacity-0">
          Full-Stack Developer & Technical Founder at RuneX
        </p>
      </div>

      <!-- Avatar & Glow (Right globally, Top on Mobile) -->
      <div class="relative z-10 flex items-center justify-center lg:w-1/2">
        <!-- Radial Glow -->
        <div class="absolute top-1/2 left-1/2 h-[350px] w-[350px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent opacity-[0.08] blur-[100px] md:h-[500px] md:w-[500px]"></div>
        
        <!-- Avatar Wrapper -->
        <div id="hero-avatar" class="relative opacity-0 inline-block after:absolute after:bottom-0 after:right-0 after:z-20 after:h-[100px] after:w-[100px] after:rounded-br-2xl after:bg-[radial-gradient(circle_at_100%_100%,#0A0A0F_40%,transparent_75%)]">
          <img 
            src="/avatar/hero-avatar.png" 
            alt="Omar Zaghloul" 
            class="relative z-10 h-auto w-full max-w-[250px] rounded-2xl object-cover drop-shadow-2xl md:max-w-[380px] lg:-ml-12 lg:max-w-[600px]"
            style="mask-image: radial-gradient(ellipse 82% 82% at 55% 48%, black 45%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse 82% 82% at 55% 48%, black 45%, transparent 75%);"
            width="450"
            height="450"
          />
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center justify-center opacity-60">
      <div class="h-12 w-[2px] overflow-hidden rounded-full bg-border/80">
        <div class="animate-scroll-down h-1/2 w-full bg-accent"></div>
      </div>
    </div>
  </section>

  <!-- Project Showcase Section (Pinned Horizontal Scroll) -->
  <section class="relative w-full bg-bg py-24" id="work">
    <!-- Progress Indicator Container -->
    <div class="fixed top-0 left-0 z-50 h-1 w-full bg-border/30 opacity-0 transition-opacity duration-300" id="work-progress-container">
      <div class="h-full w-0 bg-accent" id="work-progress-bar"></div>
    </div>

    <!-- Pinned Container -->
    <div class="relative w-full overflow-hidden" id="work-pin-container">
      <div class="px-6 lg:px-16 mb-12 flex items-end justify-between" id="work-header-container">
        <!-- Section Header -->
        <h2 id="work-header" class="font-display text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-text opacity-0">
          Selected Work
        </h2>
        
        <!-- Navigation Arrows -->
        <div class="flex gap-4 opacity-0" id="work-nav-arrows">
          <button id="scroll-left" aria-label="Scroll left" class="group flex h-12 w-12 items-center justify-center rounded-full border border-border/50 bg-surface transition-all hover:border-accent/50 hover:bg-surface/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted transition-colors group-hover:text-accent"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </button>
          <button id="scroll-right" aria-label="Scroll right" class="group flex h-12 w-12 items-center justify-center rounded-full border border-border/50 bg-surface transition-all hover:border-accent/50 hover:bg-surface/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted transition-colors group-hover:text-accent"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </button>
        </div>
      </div>

      <!-- Project Cards Horizontal Wrapper -->
      <div class="flex w-full overflow-x-auto overflow-y-hidden snap-x snap-mandatory gap-8 px-6 pb-12 md:gap-12 lg:px-16 scroll-smooth" id="work-horizontal-wrapper" style="scrollbar-width: none; -ms-overflow-style: none; -webkit-overflow-scrolling: touch;">
        <style>
          #work-horizontal-wrapper::-webkit-scrollbar { display: none; }
        </style>
        {sortedProjects.map((project, i) => (
          <a 
            href={`/projects/${project.slug}`} 
            class="project-card snap-center group relative flex w-[85vw] flex-shrink-0 flex-col overflow-hidden rounded-xl border border-border bg-surface p-6 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] hover:border-accent/40 hover:shadow-[0_0_30px_-5px_rgba(0,229,255,0.15)] md:w-[45vw] lg:w-[40vw] max-w-[800px]"
          >
            <!-- Thumbnail Image -->
            <div class="relative mb-6 aspect-[16/10] w-full overflow-hidden rounded-lg bg-bg">
              <Image 
                src={project.data.thumbnail} 
                alt={project.data.title} 
                format="webp"
                quality={80}
                class="h-full w-full object-cover transition-transform duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
                transition:name={project.slug}
              />
            </div>
            
            <!-- Card Details -->
            <div class="flex flex-col flex-grow">
              <span class="mb-3 text-xs font-semibold tracking-wider text-text-muted uppercase">
                {project.data.category}
              </span>
              <h3 class="font-display text-2xl font-bold text-text md:text-3xl">
                {project.data.title}
              </h3>
              <p class="mt-2 font-body text-base text-text-muted/80">
                {project.data.subtitle}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="relative w-full bg-bg px-6 py-32 lg:px-16" id="about">
    <div class="mx-auto w-full max-w-[900px]">
      <h2 id="about-header" class="mb-2 font-display text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-text opacity-0">
        About
      </h2>
      <h3 id="about-subheader" class="mb-12 font-display text-[clamp(1.5rem,3vw,2.5rem)] text-accent opacity-0">
        Building systems that grow with your business — not against it.
      </h3>

      <div class="flex flex-col">
        <!-- Bio Paragraphs -->
        <div class="flex flex-col gap-6 mb-16">
          <p class="about-text font-body text-[1.125rem] leading-[1.75] text-text/90 opacity-0">
            Most businesses hit a ceiling not because demand slows down, but because their internal systems can't keep up. Operations scattered across WhatsApp threads, spreadsheets, and disconnected tools. Data that lives in five places but is accurate in none of them. Teams spending hours on work that should take minutes. I build the platforms that permanently replace that friction.
          </p>
          <p class="about-text font-body text-[1.125rem] leading-[1.75] text-text/90 opacity-0">
            Through <span class="font-semibold text-accent">RuneX</span>, I partner with businesses to turn operational bottlenecks into scalable, automated infrastructure. My work spans four areas:
          </p>
        </div>

        <!-- Capability Blocks Vertical List -->
        <div class="flex flex-col gap-8 mb-12">
          <!-- Block 1 -->
          <div class="about-block flex flex-col border-l-2 border-accent pl-6 opacity-0">
            <h4 class="mb-2 font-display text-xl font-bold text-text">Custom Web & Business Platforms</h4>
            <p class="font-body text-[1.125rem] leading-[1.75] text-text-muted">
              Centralized dashboards and portals where your team manages operations and your clients track their own progress in real time. From oncology clinics coordinating treatment cycles to education agencies managing hundreds of student applications across universities — each platform is built around how your business actually runs, not how a generic tool thinks it should.
            </p>
          </div>
          
          <!-- Block 2 -->
          <div class="about-block flex flex-col border-l-2 border-accent pl-6 opacity-0">
            <h4 class="mb-2 font-display text-xl font-bold text-text">Mobile Applications</h4>
            <p class="font-body text-[1.125rem] leading-[1.75] text-text-muted">
              Cross-platform apps that put your service directly in your users' hands. From AI-powered fitness companions with integrated chatbot coaching to consumer-facing booking experiences, I build for both iOS and Android from a single codebase without compromising on feel.
            </p>
          </div>
          
          <!-- Block 3 -->
          <div class="about-block flex flex-col border-l-2 border-accent pl-6 opacity-0">
            <h4 class="mb-2 font-display text-xl font-bold text-text">AI & Workflow Automation</h4>
            <p class="font-body text-[1.125rem] leading-[1.75] text-text-muted">
              If a process is repetitive, it should be automated. I design intelligent workflows that connect your existing tools, eliminate manual data transfer, and surface insights your team would otherwise spend hours compiling. Auto-generated treatment schedules, smart document routing, pipeline triggers that fire without human intervention — the goal is always to remove the busywork so your team focuses on growth.
            </p>
          </div>

          <!-- Block 4 -->
          <div class="about-block flex flex-col border-l-2 border-accent pl-6 opacity-0">
            <h4 class="mb-2 font-display text-xl font-bold text-text">Rapid Deployment & E-Commerce</h4>
            <p class="font-body text-[1.125rem] leading-[1.75] text-text-muted">
              Not every project needs a six-month build cycle. For businesses that need to move fast — launching a booking platform, standing up a content-driven site, deploying an e-commerce storefront — I match the right technology to the timeline, getting you to market quickly with architecture that won't need to be thrown away when you scale.
            </p>
          </div>
        </div>
        
        <!-- Closing Paragraph -->
        <p class="about-closing mt-8 font-body text-[1.125rem] leading-[1.75] text-text/90 opacity-0">
          Technology only matters if it drives your business forward. I bring a background in computer engineering and product management to every engagement — which means you're not just getting a developer who writes code to spec. You're getting an architect who understands the business objective and builds the exact technical foundation to execute it. One point of contact. No handoffs. No rotating juniors.
        </p>

        <!-- Subtle Line Divider -->
        <div class="w-full h-px bg-border/40 mt-16 mb-16"></div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer />

  <script>
    import { gsap } from "gsap";
    import ScrollTrigger from "gsap/ScrollTrigger";

    // Register ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    const initAnimations = () => {
      // Accessibility Check for Reduced Motion
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        gsap.set("#hero-name, #hero-position, #hero-desc, #hero-avatar, #work-header, .project-card, #about-header, .about-text, .about-grid", { opacity: 1, y: 0, scale: 1 });
        return;
      }

      // Ensure GSAP kills old tweens if navigation event fires multiple times
      gsap.killTweensOf("#hero-name, #hero-position, #hero-desc, #hero-avatar, #work-header, .project-card, #about-header, .about-text, .about-grid");
      
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

      tl.fromTo(
        "#hero-name",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 }
      )
      .fromTo(
        "#hero-position",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 },
        "-=0.4"
      )
      .fromTo(
        "#hero-desc",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 },
        "-=0.4"
      )
      .fromTo(
        "#hero-avatar",
        { scale: 0.95, opacity: 0 },
        { scale: 1, opacity: 1, duration: 1.0 },
        0 // Starts simultaneously with the timeline
      );

      // Work section header animation
      gsap.fromTo(
        "#work-header",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#work",
            start: "top 85%",
          }
        }
      );

      // Navigation Arrows animation
      gsap.fromTo(
        "#work-nav-arrows",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#work",
            start: "top 85%",
          }
        }
      );

      // JS Scroll Logic using Arrow buttons
      const slider = document.querySelector("#work-horizontal-wrapper") as HTMLElement;
      const leftBtn = document.querySelector("#scroll-left");
      const rightBtn = document.querySelector("#scroll-right");

      if (slider && leftBtn && rightBtn) {
        // Safe card width estimation
        const scrollDistance = window.innerWidth * 0.85;

        leftBtn.addEventListener('click', () => {
          slider.scrollBy({ left: -scrollDistance, behavior: 'smooth' });
        });

        rightBtn.addEventListener('click', () => {
          slider.scrollBy({ left: scrollDistance, behavior: 'smooth' });
        });

        // Add touch-friendly drag-to-scroll allowing native gestures
        let isDown = false;
        let startX: number;
        let scrollLeft: number;

        slider.addEventListener('mousedown', (e) => {
          isDown = true;
          slider.classList.add('cursor-grabbing');
          startX = e.pageX - slider.offsetLeft;
          scrollLeft = slider.scrollLeft;
        });
        slider.addEventListener('mouseleave', () => {
          isDown = false;
          slider.classList.remove('cursor-grabbing');
        });
        slider.addEventListener('mouseup', () => {
          isDown = false;
          slider.classList.remove('cursor-grabbing');
        });
        slider.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          const x = e.pageX - slider.offsetLeft;
          const walk = (x - startX) * 2;
          slider.scrollLeft = scrollLeft - walk;
        });
      }

      // GSAP animate the newly configured project cards with simple fade up
      const cards = gsap.utils.toArray(".project-card");
      cards.forEach((card: any, index: number) => {
        gsap.fromTo(
          card,
          { y: 30, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: card,
              start: "top 85%",
            }
          }
        );
      });

      // About section header animation
      gsap.fromTo(
        "#about-header",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#about-header",
            start: "top 85%",
          }
        }
      );

      // About subheading animation
      gsap.fromTo(
        "#about-subheader",
        { y: 20, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#about-subheader",
            start: "top 85%",
          }
        }
      );

      // About bio text animation
      gsap.fromTo(
        ".about-text",
        { y: 20, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          stagger: 0.15,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-text",
            start: "top 85%",
          }
        }
      );

      // About blocks vertical list animation
      gsap.fromTo(
        ".about-block",
        { x: -20, opacity: 0 },
        {
          x: 0,
          opacity: 1,
          duration: 0.8,
          stagger: 0.15,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-block",
            start: "top 85%",
          }
        }
      );

      // About closing animation
      gsap.fromTo(
        ".about-closing",
        { y: 20, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-closing",
            start: "top 85%",
          }
        }
      );

    };

    document.addEventListener("astro:page-load", initAnimations);
  </script>

  <style>
    @keyframes scroll-down {
      0% {
        transform: translateY(-100%);
      }
      50% {
        transform: translateY(100%);
      }
      100% {
        transform: translateY(100%);
      }
    }
    .animate-scroll-down {
      animation: scroll-down 2s ease-in-out infinite;
    }
  </style>
</BaseLayout>
