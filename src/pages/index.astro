---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Omar Zaghloul — Product & Project Manager, Software Developer, AI & Automation expert & RuneX Founder"
  description="Project manager and product builder specializing in technical solutions, and AI tools."
  ogImage="/avatar/hero-avatar.png"
>
  <section class="relative flex min-h-[100dvh] w-full items-center justify-center overflow-hidden bg-bg px-6 lg:px-16 border-b border-border/50">
    <!-- Noise Overlay -->
    <div class="pointer-events-none absolute inset-0 z-0 h-full w-full opacity-[0.03]">
      <svg class="h-full w-full">
        <filter id="noise">
          <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#noise)" />
      </svg>
    </div>

    <!-- Main Hero Container -->
    <div class="relative z-10 flex w-full max-w-7xl flex-col-reverse items-center justify-between pt-24 pb-12 lg:flex-row lg:py-0">
      
      <!-- Text Content (Left) -->
      <div class="relative z-20 mt-12 flex flex-col items-center text-center lg:mt-0 lg:w-1/2 lg:items-start lg:text-left">
        <h1 id="hero-name" class="font-display text-[clamp(2.5rem,10vw,6rem)] font-bold leading-none tracking-tight text-text opacity-0">
          Omar <span class="relative inline-block whitespace-nowrap">Zaghloul<span class="absolute bottom-2 left-0 -z-10 h-[0.14em] w-full bg-accent/80"></span></span>
        </h1>
        <h2 id="hero-position" class="mt-4 font-display text-2xl font-light tracking-wide text-text/90 opacity-0 md:text-3xl">
          Engineering Digital Experiences
        </h2>
        <p id="hero-desc" class="mt-6 max-w-md font-body text-lg text-text-muted opacity-0">
          Full-Stack Developer & Technical Founder at RuneX
        </p>
      </div>

      <!-- Avatar & Glow (Right globally, Top on Mobile) -->
      <div class="relative z-10 flex items-center justify-center lg:w-1/2">
        <!-- Radial Glow -->
        <div class="absolute top-1/2 left-1/2 h-[350px] w-[350px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent opacity-[0.08] blur-[100px] md:h-[500px] md:w-[500px]"></div>
        
        <!-- Avatar Wrapper -->
        <div id="hero-avatar" class="relative opacity-0">
          <img 
            src="/avatar/hero-avatar.png" 
            alt="Omar Zaghloul" 
            class="relative z-10 h-auto w-full max-w-[200px] object-cover drop-shadow-2xl md:max-w-[300px] lg:-ml-12 lg:max-w-[450px]"
            style="mask-image: linear-gradient(to bottom, black 70%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);"
            width="450"
            height="450"
          />
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center justify-center opacity-60">
      <div class="h-12 w-[2px] overflow-hidden rounded-full bg-border/80">
        <div class="animate-scroll-down h-1/2 w-full bg-accent"></div>
      </div>
    </div>
  </section>

  <!-- Project Showcase Section (Pinned Horizontal Scroll) -->
  <section class="relative w-full bg-bg py-24" id="work">
    <!-- Progress Indicator Container -->
    <div class="fixed top-0 left-0 z-50 h-1 w-full bg-border/30 opacity-0 transition-opacity duration-300" id="work-progress-container">
      <div class="h-full w-0 bg-accent" id="work-progress-bar"></div>
    </div>

    <!-- Pinned Container -->
    <div class="relative w-full overflow-hidden" id="work-pin-container">
      <div class="px-6 lg:px-16" id="work-header-container">
        <!-- Section Header -->
        <h2 id="work-header" class="mb-12 font-display text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-text opacity-0">
          Selected Work
        </h2>
      </div>

      <!-- Project Cards Horizontal Wrapper -->
      <div class="flex w-full flex-col gap-8 px-6 pb-12 md:flex-row md:flex-nowrap md:gap-12 lg:px-16" id="work-horizontal-wrapper">
        {sortedProjects.map((project, i) => (
          <a 
            href={`/projects/${project.slug}`} 
            class="project-card group relative flex w-full flex-shrink-0 flex-col overflow-hidden rounded-xl border border-border bg-surface p-6 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] hover:border-accent/40 hover:shadow-[0_0_30px_-5px_rgba(0,229,255,0.15)] opacity-0 md:w-[45vw] lg:w-[40vw] max-w-[800px]"
          >
            <!-- Thumbnail Image -->
            <div class="relative mb-6 aspect-[16/10] w-full overflow-hidden rounded-lg bg-bg">
              <Image 
                src={project.data.thumbnail} 
                alt={project.data.title} 
                format="webp"
                quality={80}
                class="h-full w-full object-cover transition-transform duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
                transition:name={project.slug}
              />
            </div>
            
            <!-- Card Details -->
            <div class="flex flex-col flex-grow">
              <span class="mb-3 text-xs font-semibold tracking-wider text-text-muted uppercase">
                {project.data.category}
              </span>
              <h3 class="font-display text-2xl font-bold text-text md:text-3xl">
                {project.data.title}
              </h3>
              <p class="mt-2 mb-6 font-body text-base text-text-muted/80">
                {project.data.subtitle}
              </p>
              
              <!-- Tech Tags -->
              <div class="mt-auto flex flex-wrap gap-2">
                {project.data.tech.map((techItem, index) => (
                  <span class={`rounded-full bg-bg px-3 py-1 text-xs font-medium ${index === 0 ? 'text-accent border border-accent/20' : 'text-text-muted border border-border/50'}`}>
                    {techItem}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="relative w-full bg-bg px-6 py-32 lg:px-16" id="about">
    <div class="mx-auto w-full max-w-[900px]">
      <h2 id="about-header" class="mb-16 font-display text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-text opacity-0">
        About
      </h2>

      <div class="flex flex-col gap-16">
        <!-- Bio -->
        <p class="about-text font-body text-[1.25rem] leading-[1.8] text-text/90 opacity-0 md:text-[1.35rem]">
          Software engineer with an MSc in Computer Science, building full-stack web and mobile applications from Istanbul. Founder of <a href="#" class="hover-link font-semibold text-accent transition-colors hover:text-accent-dim">RuneX</a> — a development studio focused on healthcare platforms, booking systems, and SaaS tools for businesses that have outgrown spreadsheets and WhatsApp. I work across the stack with Next.js, React, Supabase, and Flutter — choosing tools that ship fast without compromising on the architecture that lets products scale.
        </p>

        <!-- Capabilities -->
        <div class="about-grid grid grid-cols-1 gap-6 opacity-0 sm:grid-cols-2">
          <!-- Item 1 -->
          <div class="flex flex-col rounded-xl border border-border/50 bg-surface/50 p-6 transition-colors hover:border-accent/40 hover:bg-surface hover:shadow-[0_0_20px_-5px_rgba(0,229,255,0.1)]">
            <span class="mb-4 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
            </span>
            <h3 class="mb-1 font-display text-lg font-bold text-text">Web Applications</h3>
            <p class="text-sm text-text-muted">Next.js, React, Astro</p>
          </div>
          <!-- Item 2 -->
          <div class="flex flex-col rounded-xl border border-border/50 bg-surface/50 p-6 transition-colors hover:border-accent/40 hover:bg-surface hover:shadow-[0_0_20px_-5px_rgba(0,229,255,0.1)]">
            <span class="mb-4 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
            </span>
            <h3 class="mb-1 font-display text-lg font-bold text-text">Mobile Development</h3>
            <p class="text-sm text-text-muted">Flutter, React Native</p>
          </div>
          <!-- Item 3 -->
          <div class="flex flex-col rounded-xl border border-border/50 bg-surface/50 p-6 transition-colors hover:border-accent/40 hover:bg-surface hover:shadow-[0_0_20px_-5px_rgba(0,229,255,0.1)]">
            <span class="mb-4 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
            </span>
            <h3 class="mb-1 font-display text-lg font-bold text-text">Backend & Infra</h3>
            <p class="text-sm text-text-muted">Supabase, Firebase, PostgreSQL</p>
          </div>
          <!-- Item 4 -->
          <div class="flex flex-col rounded-xl border border-border/50 bg-surface/50 p-6 transition-colors hover:border-accent/40 hover:bg-surface hover:shadow-[0_0_20px_-5px_rgba(0,229,255,0.1)]">
            <span class="mb-4 text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"></path><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path><path d="M2 2l7.586 7.586"></path><circle cx="11" cy="11" r="2"></circle></svg>
            </span>
            <h3 class="mb-1 font-display text-lg font-bold text-text">UI/UX Design</h3>
            <p class="text-sm text-text-muted">Figma, Design Systems</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer />

  <script>
    import { gsap } from "gsap";
    import ScrollTrigger from "gsap/ScrollTrigger";

    // Register ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    const initAnimations = () => {
      // Accessibility Check for Reduced Motion
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        gsap.set("#hero-name, #hero-position, #hero-desc, #hero-avatar, #work-header, .project-card, #about-header, .about-text, .about-grid", { opacity: 1, y: 0, scale: 1 });
        return;
      }

      // Ensure GSAP kills old tweens if navigation event fires multiple times
      gsap.killTweensOf("#hero-name, #hero-position, #hero-desc, #hero-avatar, #work-header, .project-card, #about-header, .about-text, .about-grid");
      
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

      tl.fromTo(
        "#hero-name",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 }
      )
      .fromTo(
        "#hero-position",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 },
        "-=0.4"
      )
      .fromTo(
        "#hero-desc",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 },
        "-=0.4"
      )
      .fromTo(
        "#hero-avatar",
        { scale: 0.95, opacity: 0 },
        { scale: 1, opacity: 1, duration: 1.0 },
        0 // Starts simultaneously with the timeline
      );

      // Work section header animation
      gsap.fromTo(
        "#work-header",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#work",
            start: "top 85%",
          }
        }
      );

      // Horizontal Scroll Logic using matchMedia
      let mm = gsap.matchMedia();

      // Desktop (>= 768px)
      mm.add("(min-width: 768px)", () => {
        const horizontalWrapper = document.querySelector("#work-horizontal-wrapper");
        const progressContainer = document.querySelector("#work-progress-container");
        const progressBar = document.querySelector("#work-progress-bar");
        
        // Safety check to ensure element exists before calculating
        if (!horizontalWrapper) return;

        // Force opacity to 1 immediately for desktop horizontal scroll layout
        gsap.set(".project-card", { opacity: 1, y: 0 });

        const getScrollAmount = () => {
          let horizontalWrapperWidth = horizontalWrapper.scrollWidth;
          return -(horizontalWrapperWidth - window.innerWidth + 64);
        };

        const tween = gsap.to(horizontalWrapper, {
          x: getScrollAmount,
          ease: "none",
        });

        ScrollTrigger.create({
          trigger: "#work",
          start: "top top",
          end: () => `+=${horizontalWrapper.scrollWidth - window.innerWidth}`,
          pin: true,
          animation: tween,
          scrub: 1,
          invalidateOnRefresh: true, // Recalculate on resize
          onEnter: () => gsap.to(progressContainer, { opacity: 1, duration: 0.3 }),
          onLeave: () => gsap.to(progressContainer, { opacity: 0, duration: 0.3 }),
          onEnterBack: () => gsap.to(progressContainer, { opacity: 1, duration: 0.3 }),
          onLeaveBack: () => gsap.to(progressContainer, { opacity: 0, duration: 0.3 }),
          onUpdate: (self) => {
            if (progressBar) {
              gsap.set(progressBar, { width: `${self.progress * 100}%` });
            }
          }
        });
      });

      // Mobile (< 768px)
      mm.add("(max-width: 767px)", () => {
        // Fallback to simple vertical stack fade-ins
        const cards = gsap.utils.toArray(".project-card");
        cards.forEach((card: any) => {
          gsap.fromTo(
            card,
            { y: 30, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 0.8,
              ease: "power3.out",
              scrollTrigger: {
                trigger: card,
                start: "top 85%",
              }
            }
          );
        });
      });

      // About section header animation
      gsap.fromTo(
        "#about-header",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#about-header",
            start: "top 85%",
          }
        }
      );

      // About bio text animation
      gsap.fromTo(
        ".about-text",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-text",
            start: "top 85%",
          }
        }
      );

      // About capabilities grid animation
      gsap.fromTo(
        ".about-grid",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-grid",
            start: "top 85%",
          }
        }
      );
    };

    // Astro view transitions event
    document.addEventListener("astro:page-load", initAnimations);
  </script>

  <style>
    @keyframes scroll-down {
      0% {
        transform: translateY(-100%);
      }
      50% {
        transform: translateY(100%);
      }
      100% {
        transform: translateY(100%);
      }
    }
    .animate-scroll-down {
      animation: scroll-down 2s ease-in-out infinite;
    }
  </style>
</BaseLayout>
