---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Omar Zaghloul — Product & Project Manager, Software Developer, AI & Automation expert & RuneX Founder"
  description="Project manager and product builder specializing in technical solutions, and AI tools."
  ogImage="/avatar/hero-avatar.png"
>
  <section class="relative flex min-h-[100dvh] w-full items-center justify-center overflow-hidden bg-bg px-6 lg:px-16 border-b border-border/50">
    <!-- Noise Overlay -->
    <div class="pointer-events-none absolute inset-0 z-0 h-full w-full opacity-[0.03]">
      <svg class="h-full w-full">
        <filter id="noise">
          <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch" />
        </filter>
        <rect width="100%" height="100%" filter="url(#noise)" />
      </svg>
    </div>

    <!-- Main Hero Container -->
    <div class="relative z-10 flex w-full max-w-7xl flex-col-reverse items-center justify-between pt-24 pb-12 lg:flex-row lg:py-0">
      
      <!-- Text Content (Left) -->
      <div class="relative z-20 mt-12 flex flex-col items-center text-center lg:mt-0 lg:w-1/2 lg:items-start lg:text-left">
        <h1 id="hero-name" class="font-display text-[clamp(2.5rem,10vw,6rem)] font-bold leading-none tracking-tight text-text opacity-0">
          Omar <span class="relative inline-block whitespace-nowrap">Zaghloul<span class="absolute bottom-2 left-0 -z-10 h-[0.14em] w-full bg-accent/80"></span></span>
        </h1>
        <h2 id="hero-position" class="mt-4 font-display text-2xl font-light tracking-wide text-text/90 opacity-0 md:text-3xl">
          Product Engineer & AI Automation Specialist
        </h2>
        <p id="hero-desc" class="mt-6 max-w-md font-body text-lg text-text-muted opacity-0">
          Full-Stack Developer & Technical Founder at RuneX
        </p>
      </div>

      <!-- Avatar & Glow (Right globally, Top on Mobile) -->
      <div class="relative z-10 flex items-center justify-center lg:w-1/2">
        <!-- Radial Glow -->
        <div class="absolute top-1/2 left-1/2 h-[350px] w-[350px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent opacity-[0.08] blur-[100px] md:h-[500px] md:w-[500px]"></div>
        
        <!-- Avatar Wrapper -->
        <div id="hero-avatar" class="relative opacity-0">
          <img 
            src="/avatar/hero-avatar.png" 
            alt="Omar Zaghloul" 
            class="relative z-10 h-auto w-full max-w-[200px] object-cover drop-shadow-2xl md:max-w-[300px] lg:-ml-12 lg:max-w-[450px]"
            style="mask-image: linear-gradient(to bottom, black 70%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);"
            width="450"
            height="450"
          />
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center justify-center opacity-60">
      <div class="h-12 w-[2px] overflow-hidden rounded-full bg-border/80">
        <div class="animate-scroll-down h-1/2 w-full bg-accent"></div>
      </div>
    </div>
  </section>

  <!-- Project Showcase Section (Pinned Horizontal Scroll) -->
  <section class="relative w-full bg-bg py-24" id="work">
    <!-- Progress Indicator Container -->
    <div class="fixed top-0 left-0 z-50 h-1 w-full bg-border/30 opacity-0 transition-opacity duration-300" id="work-progress-container">
      <div class="h-full w-0 bg-accent" id="work-progress-bar"></div>
    </div>

    <!-- Pinned Container -->
    <div class="relative w-full overflow-hidden" id="work-pin-container">
      <div class="px-6 lg:px-16" id="work-header-container">
        <!-- Section Header -->
        <h2 id="work-header" class="mb-12 font-display text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-text opacity-0">
          Selected Work
        </h2>
      </div>

      <!-- Project Cards Horizontal Wrapper -->
      <div class="flex w-full overflow-x-auto snap-x snap-mandatory gap-8 px-6 pb-12 md:gap-12 lg:px-16" id="work-horizontal-wrapper" style="scrollbar-width: none; -ms-overflow-style: none;">
        <style>
          #work-horizontal-wrapper::-webkit-scrollbar { display: none; }
        </style>
        {sortedProjects.map((project, i) => (
          <a 
            href={`/projects/${project.slug}`} 
            class="project-card snap-center group relative flex w-[85vw] flex-shrink-0 flex-col overflow-hidden rounded-xl border border-border bg-surface p-6 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] hover:border-accent/40 hover:shadow-[0_0_30px_-5px_rgba(0,229,255,0.15)] md:w-[45vw] lg:w-[40vw] max-w-[800px]"
          >
            <!-- Thumbnail Image -->
            <div class="relative mb-6 aspect-[16/10] w-full overflow-hidden rounded-lg bg-bg">
              <Image 
                src={project.data.thumbnail} 
                alt={project.data.title} 
                format="webp"
                quality={80}
                class="h-full w-full object-cover transition-transform duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
                transition:name={project.slug}
              />
            </div>
            
            <!-- Card Details -->
            <div class="flex flex-col flex-grow">
              <span class="mb-3 text-xs font-semibold tracking-wider text-text-muted uppercase">
                {project.data.category}
              </span>
              <h3 class="font-display text-2xl font-bold text-text md:text-3xl">
                {project.data.title}
              </h3>
              <p class="mt-2 mb-6 font-body text-base text-text-muted/80">
                {project.data.subtitle}
              </p>
              
              <!-- Tech Tags -->
              <div class="mt-auto flex flex-wrap gap-2">
                {project.data.tech.map((techItem, index) => (
                  <span class={`rounded-full bg-bg px-3 py-1 text-xs font-medium ${index === 0 ? 'text-accent border border-accent/20' : 'text-text-muted border border-border/50'}`}>
                    {techItem}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="relative w-full bg-bg px-6 py-32 lg:px-16" id="about">
    <div class="mx-auto w-full max-w-[900px]">
      <h2 id="about-header" class="mb-16 font-display text-[clamp(2.5rem,5vw,4.5rem)] font-bold tracking-tight text-text opacity-0">
        About
      </h2>

      <div class="flex flex-col">
        <!-- Bio Paragraphs -->
        <div class="flex flex-col gap-6 mb-16">
          <p class="about-text font-body text-[1.25rem] leading-[1.8] text-text/90 opacity-0 md:text-[1.35rem]">
            Most businesses I work with come to me with the same story — their operations run on WhatsApp threads, shared spreadsheets, and manual processes that worked fine at 10 clients but collapse at 50. I build the systems that replace that. Custom platforms that centralize workflows, automate the repetitive parts, and give teams one place to work instead of five.
          </p>
          <p class="about-text font-body text-[1.25rem] leading-[1.8] text-text/90 opacity-0 md:text-[1.35rem]">
            <a href="#" class="hover-link font-semibold text-accent transition-colors hover:text-accent-dim">RuneX</a> is the studio I founded to do this. Recent work includes a clinical dashboard for oncology pharmacists, a white-label application tracker for education agencies, and a booking platform for a travel operator serving multiple countries. Every project ships on a modern stack — Next.js, React, Supabase, Flutter — chosen for speed without architectural shortcuts. I hold an MSc in Computer Science and work from Istanbul.
          </p>
        </div>

        <!-- Subtle Line Divider -->
        <div class="w-full h-px bg-border/40 mb-16 relative">
          <div class="absolute left-1/2 -ml-8 -top-8 h-16 w-16 bg-bg flex items-center justify-center">
            <div class="h-2 w-2 rounded-full bg-accent/50 blur-[1px]"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer />

  <script>
    import { gsap } from "gsap";
    import ScrollTrigger from "gsap/ScrollTrigger";

    // Register ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    const initAnimations = () => {
      // Accessibility Check for Reduced Motion
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        gsap.set("#hero-name, #hero-position, #hero-desc, #hero-avatar, #work-header, .project-card, #about-header, .about-text, .about-grid", { opacity: 1, y: 0, scale: 1 });
        return;
      }

      // Ensure GSAP kills old tweens if navigation event fires multiple times
      gsap.killTweensOf("#hero-name, #hero-position, #hero-desc, #hero-avatar, #work-header, .project-card, #about-header, .about-text, .about-grid");
      
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

      tl.fromTo(
        "#hero-name",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 }
      )
      .fromTo(
        "#hero-position",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 },
        "-=0.4"
      )
      .fromTo(
        "#hero-desc",
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6 },
        "-=0.4"
      )
      .fromTo(
        "#hero-avatar",
        { scale: 0.95, opacity: 0 },
        { scale: 1, opacity: 1, duration: 1.0 },
        0 // Starts simultaneously with the timeline
      );

      // Work section header animation
      gsap.fromTo(
        "#work-header",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#work",
            start: "top 85%",
          }
        }
      );

      // Removed matchMedia horizontal pinning for native scroll experience.
      // GSAP animate the newly configured project cards with simple fade up
      const cards = gsap.utils.toArray(".project-card");
      cards.forEach((card: any) => {
        gsap.fromTo(
          card,
          { y: 30, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: card,
              start: "top 85%",
            }
          }
        );
      });

      // About section header animation
      gsap.fromTo(
        "#about-header",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: "#about-header",
            start: "top 85%",
          }
        }
      );

      // About bio text animation
      gsap.fromTo(
        ".about-text",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-text",
            start: "top 85%",
          }
        }
      );

      // About capabilities grid animation
      gsap.fromTo(
        ".about-grid",
        { y: 30, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: ".about-grid",
            start: "top 85%",
          }
        }
      );
    };

    // Astro view transitions event
    document.addEventListener("astro:page-load", initAnimations);
  </script>

  <style>
    @keyframes scroll-down {
      0% {
        transform: translateY(-100%);
      }
      50% {
        transform: translateY(100%);
      }
      100% {
        transform: translateY(100%);
      }
    }
    .animate-scroll-down {
      animation: scroll-down 2s ease-in-out infinite;
    }
  </style>
</BaseLayout>
