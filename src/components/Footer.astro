---
<footer class="border-t border-border/30 bg-bg px-6 py-32 lg:px-16" id="footer-section">
  <div class="mx-auto flex w-full max-w-7xl flex-col items-center justify-center text-center">
    
    <div class="relative mb-6 flex flex-col items-center">
      <h2 id="footer-header" class="relative font-display text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tight text-text opacity-0">
        <span data-i18n="contact.title">Let's Talk</span>
        <span class="absolute bottom-1 left-0 -z-10 h-3 w-full bg-accent/40 blur-[2px]"></span>
      </h2>
    </div>
    
    <p id="footer-subtitle" class="mb-12 max-w-xl font-body text-xl text-text-muted opacity-0" data-i18n="contact.desc">
      Have a project in mind? Let's build something together.
    </p>
    
    <a id="footer-email" href="mailto:omarhesham87878@gmail.com" class="mb-16 font-display text-[clamp(1.25rem,6vw,3.5rem)] break-all font-semibold text-text transition-colors hover:text-accent opacity-0 p-2 -m-2 max-w-full">
      omarhesham87878@gmail.com
    </a>
    
    <div id="footer-links" class="mb-16 flex gap-8 opacity-0">
      <a href="https://www.linkedin.com/in/omar-zaghloul-061021241/" target="_blank" rel="noopener noreferrer" class="hover-link font-body text-lg text-text-muted hover:text-text transition-colors p-2 -m-2">
        LinkedIn
      </a>
    </div>
    
    <p class="font-body text-sm text-text-muted/60" data-i18n="footer.copy">
      © 2026 Omar Zaghloul / RuneX
    </p>
  </div>
</footer>

<script>
  import { gsap } from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initFooterAnimation = () => {
    // Kill old tweens specifically targeted by footer
    gsap.killTweensOf("#footer-header, #footer-subtitle, #footer-email, #footer-links");

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#footer-section",
        start: "top 85%",
      }
    });

    tl.fromTo(
      "#footer-header",
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, ease: "power3.out" }
    )
    .fromTo(
      "#footer-subtitle",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.6, ease: "power3.out" },
      "-=0.4"
    )
    .fromTo(
      "#footer-email",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.6, ease: "power3.out" },
      "-=0.4"
    )
    .fromTo(
      "#footer-links",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.6, ease: "power3.out" },
      "-=0.4"
    );
  };

  document.addEventListener("astro:page-load", initFooterAnimation);
</script>
