---
const { pathname } = Astro.url;
const isProjectPage = pathname.startsWith('/projects/');
---

<header 
  id="floating-nav" 
  class="fixed left-1/2 top-6 z-[100] w-[calc(100%-2rem)] md:w-auto -translate-x-1/2 -translate-y-[150%] rounded-[9999px] border border-white/5 bg-[#111118]/70 px-6 py-3 shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-md backdrop-saturate-120 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] md:px-8"
  style="will-change: transform;"
>
  <div class="flex items-center justify-between w-full">
    <!-- Left: Logo or Back Link -->
    <a 
      href={isProjectPage ? "/" : "#"} 
      class="group relative font-display text-lg font-bold tracking-wider text-accent transition-colors hover:text-accent/80"
      data-i18n={isProjectPage ? "nav.back" : "nav.logo"}
    >
      {isProjectPage ? "← Back" : "OZ"}
    </a>

    <!-- Nav Links (visible on all screen sizes) -->
    <div class="flex items-center justify-end w-[85%] md:w-auto">
      <nav class="flex items-center gap-3 md:gap-6 ml-2 md:ml-12 overflow-x-auto whitespace-nowrap hide-scrollbar pr-2 min-w-0" style="scrollbar-width: none;">
        <style>
          nav.hide-scrollbar::-webkit-scrollbar { display: none; }
        </style>
        {isProjectPage ? (
          <>
            <a href="/#work" class="nav-link flex-shrink-0 relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent" data-i18n="nav.work">Work</a>
            <a href="/#about" class="nav-link flex-shrink-0 relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent" data-i18n="nav.about">About</a>
            <a href="/#contact" class="nav-link flex-shrink-0 relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent" data-i18n="nav.contact">Contact</a>
          </>
        ) : (
          <>
            <a href="#work" class="nav-link flex-shrink-0 relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent" data-i18n="nav.work">Work</a>
            <a href="#about" class="nav-link flex-shrink-0 relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent" data-i18n="nav.about">About</a>
            <a href="#contact" class="nav-link flex-shrink-0 relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent" data-i18n="nav.contact">Contact</a>
          </>
        )}
      </nav>

      <!-- Language Toggle -->
      <div id="language-toggle" class="flex items-center flex-shrink-0 gap-[4px] md:gap-[6px] font-display text-[0.75rem] md:text-sm font-medium ml-3 md:ml-4 pl-3 md:pl-4 border-l border-border/50">
        <button class="lang-btn text-accent transition-colors hover:text-accent" data-lang="en">EN</button>
        <span class="text-text-muted/50 text-[10px]">|</span>
        <button class="lang-btn text-text-muted transition-colors hover:text-accent" data-lang="tr">TR</button>
      </div>
    </div>
  </div>
</header>

<style>
  .backdrop-blur-md {
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
  }

  /* Nav Links Underline Animation */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-accent, #00E5FF);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  
  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-link.active {
    color: var(--color-accent, #00E5FF);
  }


  /* Language Transition Classes */
  :global(.lang-transition) {
    transition: opacity 0.2s ease-in-out !important;
  }
  :global(.lang-swapping) {
    opacity: 0 !important;
  }
</style>

<script>
  import { gsap } from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  import { translations } from "../utils/translations";

  gsap.registerPlugin(ScrollTrigger);

  const initNav = () => {
    const nav = document.getElementById('floating-nav');
    const navLinks = document.querySelectorAll('.nav-link');
    
    if (!nav) return;

    // Scroll Behavior (Show/Hide Nav)
    let lastScrollY = window.scrollY;
    
    ScrollTrigger.create({
      start: "100vh top",
      end: "max",
      onUpdate: (self) => {
        if (self.isActive && self.direction === 1) {
          // Scrolling down past 100vh - show nav
          gsap.to(nav, { y: 0, duration: 0.4, ease: "power3.out" });
        } else if (!self.isActive || (self.direction === -1 && window.scrollY < window.innerHeight)) {
          // Scrolled back near top - hide nav
          gsap.to(nav, { y: "-150%", duration: 0.4, ease: "power3.in" });
        } else if (self.isActive && self.direction === -1) {
           // still show nav when scrolling up if past 100vh
           gsap.to(nav, { y: 0, duration: 0.4, ease: "power3.out" });
        }
      }
    });

    if (window.scrollY > window.innerHeight) {
       gsap.set(nav, { y: 0 });
    }

    // Active Section highlighting
    const sections = document.querySelectorAll('section[id], footer[id]');
    
    const updateActiveLink = () => {
      const scrollPosition = window.scrollY + window.innerHeight / 3;

      let currentSectionId = "";
      sections.forEach(section => {
        const top = (section as HTMLElement).offsetTop;
        const height = (section as HTMLElement).offsetHeight;
        if (scrollPosition >= top && scrollPosition < top + height) {
          const id = section.getAttribute('id');
          if (id === 'footer-section' || id === 'contact') {
            currentSectionId = 'contact';
          } else {
            currentSectionId = id || "";
          }
        }
      });

      navLinks.forEach(link => {
        link.classList.remove('active');
        const href = link.getAttribute('href');
        if (href && (href === `#${currentSectionId}` || href === `/#${currentSectionId}`)) {
          link.classList.add('active');
        }
      });
    };

    window.addEventListener('scroll', updateActiveLink);
    updateActiveLink(); // Initial check

    // Translation Logic
    const applyTranslation = (lang: string, withAnimation = true) => {
      const t = translations[lang] || translations['en'];
      const elements = document.querySelectorAll('[data-i18n], [data-i18n-array]');
      
      const updateDom = () => {
        document.querySelectorAll("[data-i18n]").forEach(el => {
          const key = el.getAttribute("data-i18n");
          if (key && t[key]) {
            el.innerHTML = t[key];
          }
        });
        document.querySelectorAll("[data-i18n-array]").forEach(el => {
          const key = el.getAttribute("data-i18n-array");
          if (key && t[key]) {
            const contents = t[key].split('\n\n').filter(Boolean);
            el.innerHTML = contents.map(p => `<p>${p}</p>`).join('');
          }
        });
      };

      if (withAnimation) {
        elements.forEach(el => el.classList.add('lang-transition'));
        elements.forEach(el => el.classList.add('lang-swapping'));
        
        setTimeout(() => {
          updateDom();
          elements.forEach(el => el.classList.remove('lang-swapping'));
          setTimeout(() => {
            elements.forEach(el => el.classList.remove('lang-transition'));
            ScrollTrigger.refresh();
          }, 200); // Wait for fade in
        }, 200); // Wait for fade out
      } else {
        updateDom();
      }

      // Update toggles
      document.querySelectorAll(".lang-btn").forEach(btn => {
        if (btn.getAttribute("data-lang") === lang) {
          btn.classList.add("text-accent");
          btn.classList.remove("text-text-muted");
        } else {
          btn.classList.add("text-text-muted");
          btn.classList.remove("text-accent");
        }
      });
    };

    // Initialize Language from localStorage
    const savedLang = localStorage.getItem('i18n_lang') || 'en';
    if (savedLang !== 'en') {
      applyTranslation(savedLang, false);
    }

    // Toggle click events
    document.querySelectorAll(".lang-btn").forEach(btn => {
      btn.addEventListener('click', (e) => {
        const targetLang = (e.currentTarget as HTMLElement).getAttribute('data-lang');
        const currentLang = localStorage.getItem('i18n_lang') || 'en';
        if (targetLang && targetLang !== currentLang) {
          localStorage.setItem('i18n_lang', targetLang);
          applyTranslation(targetLang);
        }
      });
    });

  };

  document.addEventListener("astro:page-load", initNav);
</script>
