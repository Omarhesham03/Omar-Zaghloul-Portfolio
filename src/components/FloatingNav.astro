---
const { pathname } = Astro.url;
const isProjectPage = pathname.startsWith('/projects/');
---

<header 
  id="floating-nav" 
  class="fixed left-1/2 top-6 z-[100] w-[calc(100%-2rem)] md:w-auto -translate-x-1/2 -translate-y-[150%] rounded-[9999px] border border-white/5 bg-[#111118]/70 px-6 py-3 shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-md backdrop-saturate-120 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)] md:px-8"
  style="will-change: transform;"
>
  <div class="flex items-center justify-between gap-12">
    <!-- Left: Logo or Back Link -->
    <a 
      href={isProjectPage ? "/" : "#"} 
      class="group relative font-display text-lg font-bold tracking-wider text-accent transition-colors hover:text-accent/80"
    >
      {isProjectPage ? "← Back" : "OZ"}
    </a>

    <!-- Right: Desktop Links -->
    <nav class="hidden items-center gap-6 md:flex">
      {isProjectPage ? (
        <>
          <a href="/#work" class="nav-link relative text-sm font-medium text-text-muted transition-colors hover:text-accent">Work</a>
          <a href="/#about" class="nav-link relative text-sm font-medium text-text-muted transition-colors hover:text-accent">About</a>
          <a href="/#contact" class="nav-link relative text-sm font-medium text-text-muted transition-colors hover:text-accent">Contact</a>
        </>
      ) : (
        <>
          <a href="#work" class="nav-link relative text-sm font-medium text-text-muted transition-colors hover:text-accent">Work</a>
          <a href="#about" class="nav-link relative text-sm font-medium text-text-muted transition-colors hover:text-accent">About</a>
          <a href="#contact" class="nav-link relative text-sm font-medium text-text-muted transition-colors hover:text-accent">Contact</a>
        </>
      )}
    </nav>

    <!-- Right: Mobile Hamburger -->
    <button id="mobile-menu-btn" class="flex h-6 w-6 flex-col items-center justify-center gap-1.5 md:hidden" aria-label="Toggle menu">
      <span class="block h-[2px] w-full bg-accent transition-transform duration-300 origin-center top-line"></span>
      <span class="block h-[2px] w-full bg-accent transition-opacity duration-300 middle-line"></span>
      <span class="block h-[2px] w-full bg-accent transition-transform duration-300 origin-center bottom-line"></span>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden flex-col gap-4 pt-6 pb-2 md:hidden">
    {isProjectPage ? (
      <>
        <a href="/#work" class="mobile-link text-lg font-medium text-text-muted hover:text-accent">Work</a>
        <a href="/#about" class="mobile-link text-lg font-medium text-text-muted hover:text-accent">About</a>
        <a href="/#contact" class="mobile-link text-lg font-medium text-text-muted hover:text-accent">Contact</a>
      </>
    ) : (
      <>
        <a href="#work" class="mobile-link text-lg font-medium text-text-muted hover:text-accent">Work</a>
        <a href="#about" class="mobile-link text-lg font-medium text-text-muted hover:text-accent">About</a>
        <a href="#contact" class="mobile-link text-lg font-medium text-text-muted hover:text-accent">Contact</a>
      </>
    )}
  </div>
</header>

<style>
  .backdrop-blur-md {
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
  }

  /* Nav Links Underline Animation */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-accent, #00E5FF);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  
  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-link.active {
    color: var(--color-accent, #00E5FF);
  }

  /* Mobile hamburger open state classes */
  .menu-open .top-line {
    transform: translateY(8px) rotate(45deg);
  }
  .menu-open .middle-line {
    opacity: 0;
  }
  .menu-open .bottom-line {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  import { gsap } from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initNav = () => {
    const nav = document.getElementById('floating-nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const navLinks = document.querySelectorAll('.nav-link');
    
    if (!nav) return;

    let isMenuOpen = false;

    // Mobile Menu Toggle
    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        menuBtn?.classList.add('menu-open');
        mobileMenu?.classList.remove('hidden');
        mobileMenu?.classList.add('flex');
        
        // Expand nav container
        gsap.to(nav, {
          borderRadius: "24px",
          duration: 0.3,
          ease: "power2.out"
        });

        // Stagger links in
        gsap.fromTo(mobileLinks, 
          { x: 10, opacity: 0 },
          { x: 0, opacity: 1, duration: 0.3, stagger: 0.08, ease: "power2.out" }
        );
      } else {
        menuBtn?.classList.remove('menu-open');
        
        // Stagger links out
        gsap.to(mobileLinks, {
          x: 10, 
          opacity: 0, 
          duration: 0.2, 
          stagger: -0.05,
          ease: "power2.in",
          onComplete: () => {
            mobileMenu?.classList.add('hidden');
            mobileMenu?.classList.remove('flex');
            // Collapse nav container
            gsap.to(nav, {
              borderRadius: "9999px",
              duration: 0.3,
              ease: "power2.out"
            });
          }
        });
      }
    };

    menuBtn?.addEventListener('click', toggleMenu);
    
    // Close menu on link click
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Scroll Behavior (Show/Hide Nav)
    let lastScrollY = window.scrollY;
    
    ScrollTrigger.create({
      start: "100vh top",
      end: "max",
      onUpdate: (self) => {
        if (self.isActive && self.direction === 1) {
          // Scrolling down past 100vh - show nav
          gsap.to(nav, { y: 0, duration: 0.4, ease: "power3.out" });
        } else if (!self.isActive || (self.direction === -1 && window.scrollY < window.innerHeight)) {
          // Scrolled back near top - hide nav
          gsap.to(nav, { y: "-150%", duration: 0.4, ease: "power3.in" });
          if (isMenuOpen) toggleMenu();
        } else if (self.isActive && self.direction === -1) {
           // still show nav when scrolling up if past 100vh
           gsap.to(nav, { y: 0, duration: 0.4, ease: "power3.out" });
        }
      }
    });

    if (window.scrollY > window.innerHeight) {
       gsap.set(nav, { y: 0 });
    }

    // Active Section highlighting
    const sections = document.querySelectorAll('section[id]');
    
    const updateActiveLink = () => {
      const scrollPosition = window.scrollY + window.innerHeight / 3;

      let currentSectionId = "";
      sections.forEach(section => {
        const top = (section as HTMLElement).offsetTop;
        const height = (section as HTMLElement).offsetHeight;
        if (scrollPosition >= top && scrollPosition < top + height) {
          currentSectionId = section.getAttribute('id') || "";
        }
      });

      navLinks.forEach(link => {
        link.classList.remove('active');
        const href = link.getAttribute('href');
        if (href && (href === `#${currentSectionId}` || href === `/#${currentSectionId}`)) {
          link.classList.add('active');
        }
      });
    };

    window.addEventListener('scroll', updateActiveLink);
    updateActiveLink(); // Initial check
  };

  document.addEventListener("astro:page-load", initNav);
</script>
