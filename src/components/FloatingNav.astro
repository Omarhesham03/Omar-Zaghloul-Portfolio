---
const { pathname } = Astro.url;
const isProjectPage = pathname.startsWith('/projects/');
---

<header
  id="floating-nav"
  class="fixed left-1/2 top-6 z-[100] w-[calc(100%-2rem)] md:w-auto -translate-x-1/2 -translate-y-[150%] rounded-[9999px] border border-white/5 bg-[#111118]/70 px-4 py-2 md:px-8 md:py-3 shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur-md backdrop-saturate-120 transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)]"
  style="will-change: transform;"
>
  <div class="flex items-center justify-between">
    <!-- Left: Logo or Back Link -->
    <a
      href={isProjectPage ? "/" : "#"}
      class="group relative font-display text-lg font-bold tracking-wider text-accent transition-colors hover:text-accent/80"
    >
      {isProjectPage ? "← Back" : "OZ"}
    </a>

    <!-- Nav Links (visible on all screen sizes) -->
    <nav class="flex items-center gap-3 md:gap-6 ml-4 md:ml-12">
      {isProjectPage ? (
        <>
          <a href="/#work" class="nav-link relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent">Work</a>
          <a href="/#about" class="nav-link relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent">About</a>
          <a href="/#contact" class="nav-link relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent">Contact</a>
        </>
      ) : (
        <>
          <a href="#work" class="nav-link relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent">Work</a>
          <a href="#about" class="nav-link relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent">About</a>
          <a href="#contact" class="nav-link relative text-[0.75rem] md:text-sm font-medium text-text-muted transition-colors hover:text-accent">Contact</a>
        </>
      )}
    </nav>
  </div>
</header>

<style>
  .backdrop-blur-md {
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
  }

  /* Nav Links Underline Animation */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-accent, #00E5FF);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-link.active {
    color: var(--color-accent, #00E5FF);
  }
</style>

<script>
  import { gsap } from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initNav = () => {
    const nav = document.getElementById('floating-nav');
    const navLinks = document.querySelectorAll('.nav-link');

    if (!nav) return;

    // Scroll Behavior (Show/Hide Nav)
    ScrollTrigger.create({
      start: "100vh top",
      end: "max",
      onUpdate: (self) => {
        if (self.isActive && self.direction === 1) {
          // Scrolling down past 100vh - show nav
          gsap.to(nav, { y: 0, duration: 0.4, ease: "power3.out" });
        } else if (!self.isActive || (self.direction === -1 && window.scrollY < window.innerHeight)) {
          // Scrolled back near top - hide nav
          gsap.to(nav, { y: "-150%", duration: 0.4, ease: "power3.in" });
        } else if (self.isActive && self.direction === -1) {
           // still show nav when scrolling up if past 100vh
           gsap.to(nav, { y: 0, duration: 0.4, ease: "power3.out" });
        }
      }
    });

    if (window.scrollY > window.innerHeight) {
       gsap.set(nav, { y: 0 });
    }

    // Active Section highlighting
    const sections = document.querySelectorAll('section[id], footer[id]');

    const updateActiveLink = () => {
      const scrollPosition = window.scrollY + window.innerHeight / 3;

      let currentSectionId = "";
      sections.forEach(section => {
        const top = (section as HTMLElement).offsetTop;
        const height = (section as HTMLElement).offsetHeight;
        if (scrollPosition >= top && scrollPosition < top + height) {
          currentSectionId = section.getAttribute('id') || "";
        }
      });

      navLinks.forEach(link => {
        link.classList.remove('active');
        const href = link.getAttribute('href');
        if (href && (href === `#${currentSectionId}` || href === `/#${currentSectionId}`)) {
          link.classList.add('active');
        }
      });
    };

    window.addEventListener('scroll', updateActiveLink);
    updateActiveLink(); // Initial check
  };

  document.addEventListener("astro:page-load", initNav);
</script>
